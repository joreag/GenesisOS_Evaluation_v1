{
    "MdoObject": {
        "id": "mdo_mdoobject",
        "meta": {
            "language": "Genesis",
            "version": "v0.2"
        },
        "MAP": {
            "variables": {
                "object_id": {
                    "name": "object_id",
                    "kind": "requires",
                    "type": "String",
