                        "op": "==",
                        "left": {
                            "type": "Variable",
                            "name": "mime_type"
                        },
                        "right": {
                            "type": "Literal",
                            "value": "\"executable/genlang\"",
                            "dataType": "String"
                        }
                    }
                },
                "body": [
                    {
                        "type": "Assertion",
                        "condition": {
                            "type": "BinaryOp",
                            "op": "==",
                            "left": {
                                "type": "Variable",
                                "name": "requestor_id"
                            },
                            "right": {
                                "type": "Literal",
                                "value": "\"System_Compiler\"",
                                "dataType": "String"
                            }
                        },
                        "on_fail": {
                            "action": "Dissonance",
                            "message": {
                                "type": "Literal",
                                "value": "\"Security Violation: Only the Compiler may modify executable objects.\"",
                                "dataType": "String"
                            }
                        }
                    },
                    {
                        "type": "Assertion",
                        "condition": {
                            "type": "BinaryOp",
                            "op": "==",
                            "left": {
                                "type": "FunctionCall",
                                "function_name": "is_session_valid",
                                "arguments": [
                                    {
                                        "type": "Variable",
                                        "name": "requestor_token"
                                    }
                                ]
                            },
                            "right": {
                                "type": "Literal",
                                "value": true,
                                "dataType": "Bool"
                            }
                        },
                        "on_fail": {
                            "action": "Dissonance",
                            "message": {
                                "type": "Literal",
                                "value": "\"Security Violation: Invalid or missing session token.\"",
                                "dataType": "String"
                            }
                        }
                    }
                ]
            }
        ],
        "TRANSFORM": [
            {
                "type": "If",
                "condition": {
                    "type": "BinaryOp",
                    "op": "==",
                    "left": {
                        "type": "Variable",
                        "name": "action"
                    },
                    "right": {
                        "type": "Literal",
