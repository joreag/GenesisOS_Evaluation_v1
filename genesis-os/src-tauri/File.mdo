            {
                "type": "If",
                "condition": {
                    "type": "BinaryOp",
                    "op": "==",
                    "left": {
                        "type": "Variable",
                        "name": "action"
                    },
                    "right": {
                        "type": "Literal",
                        "value": "\"OVERWRITE\"",
