                            },
                            "right": {
                                "type": "Variable",
                                "name": "system_max_file_size"
                            }
                        },
                        "on_fail": {
                            "action": "Dissonance",
                            "message": {
                                "type": "Literal",
                                "value": "\"Resource Exhaustion: Max file size exceeded.\"",
                                "dataType": "String"
                            }
                        }
                    },
                    {
                        "type": "Assertion",
                        "condition": {
                            "type": "BinaryOp",
                            "op": "<=",
                            "left": {
                                "type": "Variable",
                                "name": "input_offset"
                            },
                            "right": {
                                "type": "Variable",
                                "name": "size"
                            }
                        },
                        "on_fail": {
                            "action": "Dissonance",
                            "message": {
                                "type": "Literal",
                                "value": "\"Memory Violation: Write offset out of bounds (Sparse files disallowed).\"",
                                "dataType": "String"
                            }
                        }
                    },
                    {
                        "type": "Assertion",
                        "condition": {
                            "type": "BinaryOp",
                            "op": "==",
                            "left": {
