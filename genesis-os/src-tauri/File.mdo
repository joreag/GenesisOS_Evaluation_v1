                            }
                        },
                        {
                            "type": "Variable",
                            "name": "size"
                        }
                    ]
                }
            }
        ],
        "CHECK": [
            {
                "type": "If",
                "condition": {
                    "type": "BinaryOp",
                    "op": "||",
                    "left": {
                        "type": "BinaryOp",
                        "op": "==",
                        "left": {
                            "type": "Variable",
                            "name": "action"
                        },
                        "right": {
                            "type": "Literal",
