                                "dataType": "Bool"
                            }
                        },
                        "on_fail": {
                            "action": "Dissonance",
                            "message": {
                                "type": "Literal",
                                "value": "\"Security Violation: Invalid or missing session token.\"",
                                "dataType": "String"
                            }
                        }
                    }
                ]
            },
            {
                "type": "If",
                "condition": {
                    "type": "BinaryOp",
                    "op": "&&",
                    "left": {
                        "type": "BinaryOp",
                        "op": "==",
                        "left": {
                            "type": "Variable",
                            "name": "action"
                        },
